# ------------------------------------------------------------
# Oficina Pro API - variáveis de ambiente
# Copie este arquivo para `apps/api/.env` e preencha os valores.
# ------------------------------------------------------------

# -------- Banco de dados --------
# Supabase (direct connection) - porta 5432, ideal para desenvolvimento e Alembic:
#   postgresql://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres
# Supabase (transaction pooler) - porta 6543, recomendado para apps serverless:
#   postgresql://postgres.<PROJECT_REF>:<DB_PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres
#
# Observações:
# - Pode colar a string com o schema `postgresql://` que o backend converte
#   automaticamente para `postgresql+psycopg://` e acrescenta `sslmode=require`
#   quando o host for `*.supabase.co` / `*.supabase.com`.
# - Para Postgres local (Docker Compose), use:
#   postgresql+psycopg://postgres:postgres@localhost:5432/oficina_pro
DATABASE_URL=postgresql://postgres:<DB_PASSWORD>@db.paditvetvgtyriooiabs.supabase.co:5432/postgres

# -------- Supabase (opcional, para Storage / Realtime / Auth futuros) --------
SUPABASE_URL=https://paditvetvgtyriooiabs.supabase.co
SUPABASE_ANON_KEY=sb_publishable_dp34TL3Xlofe92LqQr8DpA_VdsCk_Ti
# Nunca comitar; pegue em Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=

# -------- JWT da API --------
# Em produção, gere algo longo e aleatório (ex.: `openssl rand -hex 32`).
JWT_SECRET_KEY=change-me-in-production-at-least-32-bytes-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FORGOT_PASSWORD_EXPIRE_MINUTES=30
