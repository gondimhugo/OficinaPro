# ------------------------------------------------------------
# Oficina Pro - Admin Web (Next.js) - variaveis de ambiente
# Copie para `apps/admin-web/.env.local` em desenvolvimento, ou
# configure no painel Vercel (Settings -> Environment Variables).
#
# A Integracao Supabase <-> Vercel popula estas duas variaveis
# automaticamente quando conectada. Nao comitar valores reais.
# ------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Opcional - apenas em Route Handlers / Server Actions. NUNCA expor ao browser.
SUPABASE_SERVICE_ROLE_KEY=
